DATABASE_URL="postgresql://user:password@host-pooler:5432/easy_rechnung"
DIRECT_DATABASE_URL="postgresql://user:password@host-direct:5432/easy_rechnung"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# Vercel Blob (get from Vercel dashboard → Storage → Blob → your store → .env.local)
PUBLIC_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Local dev only: path to Chrome/Chromium executable for PDF generation
# Not needed on Vercel (uses @sparticuz/chromium automatically)
PUPPETEER_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
